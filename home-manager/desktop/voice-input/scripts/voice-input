#!/usr/bin/env bash
# Toggle voice input: press once to start recording, again to stop and transcribe.
# Transcription goes through a locally lazy-launched whisper-server (medium, ja)
# so the model stays warm in GPU memory across invocations.
# With --refine flag, post-processes via OpenRouter LLM API.

set -euo pipefail

REFINE=false
[[ "${1:-}" == "--refine" ]] && REFINE=true

PIDFILE="/tmp/voice-input.pid"
MODEFILE="/tmp/voice-input.mode"
AUDIO="/tmp/voice-input.wav"
MODEL_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/whisper-models"
MODEL="$MODEL_DIR/ggml-medium.bin"
MODEL_URL="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-medium.bin"
API_KEY_FILE="/run/secrets/voice_input_openrouter_api_key"
WHISPER_HOST="127.0.0.1"
WHISPER_PORT="8080"
WHISPER_URL="http://${WHISPER_HOST}:${WHISPER_PORT}"
WHISPER_LOG="/tmp/whisper-server.log"

ensure_model() {
  if [[ ! -f "$MODEL" ]]; then
    mkdir -p "$MODEL_DIR"
    notify-send "Voice Input" "Downloading whisper model (medium)..." -t 5000
    curl -L -o "$MODEL" "$MODEL_URL"
    notify-send "Voice Input" "Model download complete" -t 3000
  fi
}

ensure_server() {
  if curl -s -o /dev/null --max-time 1 "${WHISPER_URL}/" 2>/dev/null; then
    return 0
  fi
  ensure_model
  nohup whisper-server -m "$MODEL" -l ja --port "$WHISPER_PORT" -nt \
    >"$WHISPER_LOG" 2>&1 &
  disown
  for _ in $(seq 1 60); do
    sleep 0.5
    if curl -s -o /dev/null --max-time 1 "${WHISPER_URL}/" 2>/dev/null; then
      return 0
    fi
  done
  notify-send "Voice Input" "whisper-server failed to start" -t 3000
  return 1
}

refine_text() {
  local raw="$1"
  if [[ -z "$API_KEY_FILE" || ! -f "$API_KEY_FILE" ]]; then
    notify-send "Voice Input" "API key not found, skipping refinement" -t 2000
    echo "$raw"
    return
  fi

  local api_key
  api_key=$(cat "$API_KEY_FILE")

  local prompt
  prompt="以下は日本語の音声認識結果です。句読点の補完、フィラー（えーと、あのー等）の除去、明らかな誤認識の修正を行い、整形後のテキストのみを出力してください。余計な説明は不要です。

$raw"

  local payload
  payload=$(jq -n --arg model "anthropic/claude-3-haiku" --arg content "$prompt" \
    '{model: $model, messages: [{role: "user", content: $content}]}')

  local response
  response=$(curl -s --max-time 10 \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -d "$payload" \
    https://openrouter.ai/api/v1/chat/completions)

  local refined
  refined=$(echo "$response" | jq -r '.choices[0].message.content // empty' 2>/dev/null)

  if [[ -n "$refined" ]]; then
    echo "$refined"
  else
    echo "$raw"
  fi
}

start_recording() {
  ensure_server &
  if [[ "$REFINE" == true ]]; then
    echo "refine" > "$MODEFILE"
    notify-send "Voice Input (LLM)" "Recording... Press Super+Shift+M to stop" -t 2000
  else
    echo "raw" > "$MODEFILE"
    notify-send "Voice Input" "Recording... Press Super+M to stop" -t 2000
  fi
  rec -q -r 16000 -c 1 -b 16 "$AUDIO" &
  echo $! > "$PIDFILE"
}

stop_and_transcribe() {
  local pid
  pid=$(cat "$PIDFILE")
  rm -f "$PIDFILE"
  kill "$pid" 2>/dev/null || true
  wait "$pid" 2>/dev/null || true

  local mode="raw"
  [[ -f "$MODEFILE" ]] && mode=$(cat "$MODEFILE") && rm -f "$MODEFILE"

  if [[ ! -f "$AUDIO" ]]; then
    notify-send "Voice Input" "No audio recorded" -t 2000
    exit 1
  fi

  notify-send "Voice Input" "Transcribing..." -t 2000
  ensure_server

  local text
  text=$(curl -s --max-time 30 \
    -F "file=@$AUDIO" \
    -F "language=ja" \
    -F "response_format=text" \
    -F "no_timestamps=true" \
    "${WHISPER_URL}/inference" \
    | sed '/^$/d; s/^ *//; s/ *$//' \
    | tr -d '\n')

  rm -f "$AUDIO"

  if [[ -z "$text" ]]; then
    notify-send "Voice Input" "No speech detected" -t 2000
    exit 0
  fi

  if [[ "$mode" == "refine" ]]; then
    notify-send "Voice Input" "Refining with LLM..." -t 2000
    text=$(refine_text "$text")
  fi

  wtype -- "$text"
  notify-send "Voice Input" "$text" -t 3000
}

if [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
  stop_and_transcribe
else
  rm -f "$PIDFILE"
  start_recording
fi
