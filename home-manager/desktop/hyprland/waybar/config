        },
        "format-full": "σΑ²Ö",
        "tooltip-format-discharging": "{power:>1.0f}WβÜ™ {capacity}%",
        "tooltip-format-charging": "{power:>1.0f}WβÜë {capacity}%",
        "interval": 5,
        "on-click": "wlogout",
        "states": {
            "warning": 20,
            "critical": 10
        }
    },

    "bluetooth": {
        "format": "",
        "format-off": "σΑ²≤",
        "format-disabled": "σΑ²≤",
        "format-connected": "σΑ²±",
        "format-no-controller": "",
