#!/bin/bash

# Settings menu via Walker dmenu.
# Opens various system control TUIs and tools.

menu="箚ㄸ  WiFi	wifi
箚궚  Bluetooth	bluetooth
箚빢  Audio Output	audio
箚뜫  Audio Mixer	mixer
箚뙆  Keybindings	keybindings"

selected=$(echo "$menu" | walker --dmenu -p "Settings")

[ -z "$selected" ] && exit 0

action=$(echo "$selected" | awk -F'\t' '{print $NF}')

tui() { alacritty --class tui-float -e "$@" & }

case "$action" in
  wifi)       tui nmtui ;;
  bluetooth)  tui bluetui ;;
  audio)      switch-audio ;;
  mixer)      tui wiremix -v output ;;
  keybindings) tui bash -c 'hyprctl binds | less' ;;
esac
